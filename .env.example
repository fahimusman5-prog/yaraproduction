# Optional public WhatsApp numbers, in international format without + or spaces.
# The storefront uses its existing numbers when these variables are omitted.
NEXT_PUBLIC_WHATSAPP_NUMBER_SRI_LANKA=94741266855
NEXT_PUBLIC_WHATSAPP_NUMBER_UAE=971543702924

# Optional official Facebook page. Leave blank until a verified YARA page URL is available.
NEXT_PUBLIC_YARA_FACEBOOK_URL=

# Required for admin and POS. Use the publishable key, never the service role key.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key

# Server only. Never prefix these with NEXT_PUBLIC_.
SUPABASE_SECRET_KEY=sb_secret_your_key
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-only HMAC secret used to authorize guest order-status lookups.
ORDER_TRACKING_SECRET=replace-with-a-long-random-secret

# PayHere merchant credentials. Use sandbox=true until merchant approval is complete.
PAYHERE_MERCHANT_ID=
PAYHERE_MERCHANT_SECRET=
PAYHERE_SANDBOX=true
